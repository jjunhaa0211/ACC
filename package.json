{
  "name": "acc-static-web",
  "version": "1.0.0",
  "private": true,
  "description": "Static web demo with production-grade CI/CD pipelines.",
  "scripts": {
    "serve:ci": "node .github/scripts/serve-static-ci.mjs . 4173",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "acc-ci": "node acci/bin/acc-ci.mjs",
    "acc-ci:init": "node acci/bin/acc-ci.mjs init --project .",
    "acc-ci:bootstrap": "node acci/bin/acc-ci.mjs bootstrap --project . --provider github",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=github,html",
    "capture:pr-screenshot": "node .github/scripts/capture-pr-screenshot.mjs",
    "capture:pr-video": "node .github/scripts/capture-pr-video.mjs",
    "test:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "test:mock": "node --test tests/generated",
    "test:ci:universal": "npm run lint --if-present && npm run test:mock --if-present && npm run test --if-present && npm run test:e2e:ci --if-present"
  },
  "bin": {
    "acc-ci": "acci/bin/acc-ci.mjs"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.0.3",
    "@eslint/js": "^9.22.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.22.0",
    "globals": "^17.5.0"
  }
}
